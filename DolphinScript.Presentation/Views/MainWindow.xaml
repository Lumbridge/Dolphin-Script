<Window x:Class="DolphinScript.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dolphin Script"
        Width="1280"
        Height="820"
        MinWidth="1040"
        MinHeight="680"
        Background="#F4F7FA"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <SolidColorBrush x:Key="AppBackground" Color="#F4F7FA" />
        <SolidColorBrush x:Key="PanelBackground" Color="#FFFFFF" />
        <SolidColorBrush x:Key="TextPrimary" Color="#1F2937" />
        <SolidColorBrush x:Key="TextMuted" Color="#667085" />
        <SolidColorBrush x:Key="LineBrush" Color="#D8DEE8" />
        <SolidColorBrush x:Key="AccentBrush" Color="#0F766E" />
        <SolidColorBrush x:Key="AccentDarkBrush" Color="#115E59" />
        <SolidColorBrush x:Key="DangerBrush" Color="#B42318" />
        <SolidColorBrush x:Key="ToolBrush" Color="#EEF2F6" />

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="MutedText" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
            <Setter Property="Foreground" Value="{StaticResource TextMuted}" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="Height" Value="34" />
            <Setter Property="MinWidth" Value="92" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="Margin" Value="0,0,8,8" />
            <Setter Property="Background" Value="{StaticResource ToolBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.45" />
                    <Setter Property="Cursor" Value="Arrow" />
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E3E8EF" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="AccentButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="MinWidth" Value="150" />
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource AccentDarkBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Foreground" Value="{StaticResource DangerBrush}" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="8,4" />
        </Style>

        <Style x:Key="SectionBorder" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelBackground}" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="14" />
            <Setter Property="Margin" Value="0,0,0,12" />
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource AppBackground}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Menu Grid.Row="0" Background="White" BorderBrush="{StaticResource LineBrush}" BorderThickness="0,0,0,1">
            <MenuItem Header="File">
                <MenuItem Header="Save Script" Command="{Binding SaveCommand}" />
                <MenuItem Header="Load Script" Command="{Binding LoadCommand}" />
                <Separator />
                <MenuItem Header="Refresh" Command="{Binding RefreshCommand}" />
            </MenuItem>
            <MenuItem Header="Help">
                <MenuItem Header="Wiki" Command="{Binding WikiCommand}" />
                <MenuItem Header="About" Command="{Binding AboutCommand}" />
            </MenuItem>
        </Menu>

        <Grid Grid.Row="1" Margin="18,16,18,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal">
                <Border Width="42" Height="42" CornerRadius="8" Background="{StaticResource AccentBrush}" Margin="0,0,12,0">
                    <TextBlock Text="DS" Foreground="White" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <StackPanel>
                    <TextBlock Text="Dolphin Script" FontSize="22" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding StatusText}" Style="{StaticResource MutedText}" />
                </StackPanel>
            </StackPanel>

            <Button Grid.Column="1" Content="{Binding StartButtonText}" Command="{Binding StartScriptCommand}" Style="{StaticResource AccentButton}" />
        </Grid>

        <Grid Grid.Row="2" Margin="18,0,18,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.55*" />
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource SectionBorder}" Margin="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" LastChildFill="False" Margin="0,0,0,10">
                        <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                            <Button Content="Up" Command="{Binding MoveEventUpCommand}" />
                            <Button Content="Down" Command="{Binding MoveEventDownCommand}" />
                            <Button Content="Remove" Command="{Binding RemoveEventCommand}" Style="{StaticResource DangerButton}" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                            <TextBlock Text="Repeat" Style="{StaticResource MutedText}" Margin="0,0,8,8" />
                            <TextBox Width="54" Text="{Binding RepeatAmount, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,8" />
                            <Button Content="Add Group" Command="{Binding AddRepeatGroupCommand}" />
                            <Button Content="Remove Group" Command="{Binding RemoveRepeatGroupCommand}" />
                        </StackPanel>
                    </DockPanel>

                    <DataGrid x:Name="EventsGrid"
                              Grid.Row="1"
                              ItemsSource="{Binding Events}"
                              SelectedItem="{Binding SelectedEvent, Mode=TwoWay}"
                              SelectionChanged="EventsGrid_SelectionChanged"
                              MouseDoubleClick="EventsGrid_MouseDoubleClick"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              IsReadOnly="True"
                              SelectionMode="Extended"
                              SelectionUnit="FullRow"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              RowHeaderWidth="0"
                              BorderBrush="{StaticResource LineBrush}"
                              BorderThickness="1"
                              Background="White"
                              AlternatingRowBackground="#F8FAFC">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="#" Binding="{Binding Index}" Width="54" />
                            <DataGridTextColumn Header="Event" Binding="{Binding ScriptEventName}" Width="145" />
                            <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="2*" />
                            <DataGridTextColumn Header="Group" Binding="{Binding GroupId}" Width="72" />
                            <DataGridTextColumn Header="Repeat" Binding="{Binding RepeatCount}" Width="72" />
                            <DataGridTextColumn Header="Window" Binding="{Binding WindowTitle}" Width="140" />
                            <DataGridTextColumn Header="Process" Binding="{Binding ProcessName}" Width="110" />
                            <DataGridTextColumn Header="Current Action" Binding="{Binding CurrentAction}" Width="190" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <TextBlock Grid.Row="2" Text="{Binding Events.Count, StringFormat={}{0} events}" Style="{StaticResource MutedText}" Margin="0,10,0,0" />
                </Grid>
            </Border>

            <TabControl Grid.Column="2" Background="Transparent" BorderThickness="0" IsEnabled="{Binding CanEditEvents}">
                <TabItem Header="Pause">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="0,12,0,0">
                            <Border Style="{StaticResource SectionBorder}">
                                <StackPanel>
                                    <TextBlock Text="Time pauses" FontWeight="SemiBold" Margin="0,0,0,10" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="12" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="Fixed seconds" Style="{StaticResource MutedText}" Margin="0,0,0,4" />
                                            <TextBox Text="{Binding FixedDelay, UpdateSourceTrigger=PropertyChanged}" />
                                            <Button Content="Add Fixed Pause" Command="{Binding AddFixedPauseCommand}" Margin="0,10,0,0" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="Random range" Style="{StaticResource MutedText}" Margin="0,0,0,4" />
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="8" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <TextBox Text="{Binding MinimumRandomDelay, UpdateSourceTrigger=PropertyChanged}" />
                                                <TextBox Grid.Column="2" Text="{Binding MaximumRandomDelay, UpdateSourceTrigger=PropertyChanged}" />
                                            </Grid>
                                            <Button Content="Add Random Pause" Command="{Binding AddRandomPauseCommand}" Margin="0,10,0,0" />
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource SectionBorder}">
                                <StackPanel>
                                    <TextBlock Text="Colour pauses" FontWeight="SemiBold" Margin="0,0,0,10" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Button Content="Exists In Area" Command="{Binding AddOverlayEventCommand}" CommandParameter="PauseWhileColourExistsInArea" />
                                        <Button Grid.Column="2" Content="Missing In Area" Command="{Binding AddOverlayEventCommand}" CommandParameter="PauseWhileColourDoesntExistInArea" />
                                        <Button Grid.Column="0" Margin="0,42,8,0" Content="Exists On Window" Command="{Binding AddOverlayEventCommand}" CommandParameter="PauseWhileColourExistsInAreaOnWindow" />
                                        <Button Grid.Column="2" Margin="0,42,0,0" Content="Missing On Window" Command="{Binding AddOverlayEventCommand}" CommandParameter="PauseWhileColourDoesntExistInAreaOnWindow" />
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="Keyboard">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="0,12,0,0">
                            <Border Style="{StaticResource SectionBorder}">
                                <StackPanel>
                                    <TextBlock Text="Keyboard event" FontWeight="SemiBold" Margin="0,0,0,10" />
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <ComboBox ItemsSource="{Binding SpecialKeys}" SelectedItem="{Binding SelectedSpecialKey}" />
                                        <Button Grid.Column="2" Content="Insert Key" Command="{Binding AddSpecialKeyCommand}" />
                                    </Grid>
                                    <TextBox Text="{Binding KeyboardText, UpdateSourceTrigger=PropertyChanged}" Height="120" AcceptsReturn="True" TextWrapping="Wrap" VerticalContentAlignment="Top" />
                                    <Button Content="Add Keypress" Command="{Binding AddKeyboardCommand}" Margin="0,10,0,0" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="Mouse Move">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="0,12,0,0">
                            <Border Style="{StaticResource SectionBorder}">
                                <StackPanel>
                                    <TextBlock Text="Mouse movement" FontWeight="SemiBold" Margin="0,0,0,10" />
                                    <ComboBox ItemsSource="{Binding MouseMovementModes}" SelectedItem="{Binding SelectedMouseMovementMode}" Margin="0,0,0,10" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="12" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="Minimum speed" Style="{StaticResource MutedText}" />
                                            <Slider Minimum="0" Maximum="100" Value="{Binding MinimumMouseSpeed}" />
                                            <TextBlock Text="{Binding MinimumMouseSpeed}" Style="{StaticResource MutedText}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="Maximum speed" Style="{StaticResource MutedText}" />
                                            <Slider Minimum="0" Maximum="100" Value="{Binding MaximumMouseSpeed}" />
                                            <TextBlock Text="{Binding MaximumMouseSpeed}" Style="{StaticResource MutedText}" />
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource SectionBorder}">
                                <StackPanel>
                                    <TextBlock Text="Screen" FontWeight="SemiBold" Margin="0,0,0,8" />
                                    <TextBlock Text="{Binding MouseScreenPosition}" Style="{StaticResource MutedText}" Margin="0,0,0,8" />
                                    <Button Content="Fixed Point" Command="{Binding AddOverlayEventCommand}" CommandParameter="MouseMove" />
                                    <Button Content="Random Area" Command="{Binding AddOverlayEventCommand}" CommandParameter="MouseMoveToArea" />
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource SectionBorder}">
                                <StackPanel>
                                    <TextBlock Text="Active window" FontWeight="SemiBold" Margin="0,0,0,8" />
                                    <TextBlock Text="{Binding ActiveWindowTitle}" Style="{StaticResource MutedText}" TextTrimming="CharacterEllipsis" Margin="0,0,0,4" />
                                    <TextBlock Text="{Binding MouseWindowPosition}" Style="{StaticResource MutedText}" Margin="0,0,0,8" />
                                    <Button Content="Fixed Point On Window" Command="{Binding AddWindowSelectionEventCommand}" CommandParameter="MouseMoveToPointOnWindow" />
                                    <Button Content="Random Area On Window" Command="{Binding AddWindowSelectionEventCommand}" CommandParameter="MouseMoveToAreaOnWindow" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="Mouse Colour">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="0,12,0,0">
                            <Border Style="{StaticResource SectionBorder}">
                                <StackPanel>
                                    <TextBlock Text="Colour under mouse" FontWeight="SemiBold" Margin="0,0,0,10" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="54" />
                                            <ColumnDefinition Width="12" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border Width="54" Height="34" Background="{Binding CurrentColourBrush}" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="6" />
                                        <TextBlock Grid.Column="2" Text="{Binding CurrentColourHex}" Style="{StaticResource MutedText}" />
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource SectionBorder}">
                                <StackPanel>
                                    <TextBlock Text="Colour search" FontWeight="SemiBold" Margin="0,0,0,10" />
                                    <Button Content="Search Screen Area" Command="{Binding AddOverlayEventCommand}" CommandParameter="MouseMoveToColour" />
                                    <Button Content="Search Window Area" Command="{Binding AddWindowSelectionEventCommand}" CommandParameter="MouseMoveToColourOnWindow" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="Mouse Click">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="0,12,0,0">
                            <Border Style="{StaticResource SectionBorder}">
                                <StackPanel>
                                    <TextBlock Text="Click" FontWeight="SemiBold" Margin="0,0,0,10" />
                                    <UniformGrid Columns="3">
                                        <Button Content="Left" Command="{Binding AddMouseClickCommand}" CommandParameter="LeftClick" />
                                        <Button Content="Middle" Command="{Binding AddMouseClickCommand}" CommandParameter="MiddleClick" />
                                        <Button Content="Right" Command="{Binding AddMouseClickCommand}" CommandParameter="RightClick" />
                                    </UniformGrid>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource SectionBorder}">
                                <StackPanel>
                                    <TextBlock Text="Button down" FontWeight="SemiBold" Margin="0,0,0,10" />
                                    <UniformGrid Columns="3">
                                        <Button Content="Left" Command="{Binding AddMouseClickCommand}" CommandParameter="LmbDown" />
                                        <Button Content="Middle" Command="{Binding AddMouseClickCommand}" CommandParameter="MmbDown" />
                                        <Button Content="Right" Command="{Binding AddMouseClickCommand}" CommandParameter="RmbDown" />
                                    </UniformGrid>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource SectionBorder}">
                                <StackPanel>
                                    <TextBlock Text="Button up" FontWeight="SemiBold" Margin="0,0,0,10" />
                                    <UniformGrid Columns="3">
                                        <Button Content="Left" Command="{Binding AddMouseClickCommand}" CommandParameter="LmbUp" />
                                        <Button Content="Middle" Command="{Binding AddMouseClickCommand}" CommandParameter="MmbUp" />
                                        <Button Content="Right" Command="{Binding AddMouseClickCommand}" CommandParameter="RmbUp" />
                                    </UniformGrid>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
            </TabControl>
        </Grid>
    </Grid>
</Window>
<Window x:Class="DolphinScript.Views.LiveSelectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dolphin Script selection overlay"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        Cursor="Cross"
        KeyDown="Window_KeyDown"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        MouseMove="Window_MouseMove"
        MouseLeftButtonUp="Window_MouseLeftButtonUp"
        MouseRightButtonUp="Window_MouseRightButtonUp">
    <Window.ContextMenu>
        <ContextMenu x:Name="SelectionContextMenu">
            <MenuItem x:Name="SaveMenuItem" Header="Save selection" IsEnabled="False" Click="SaveMenuItem_Click" />
            <MenuItem x:Name="QuickRegistrationMenuItem" Header="Quick registration" IsCheckable="True" Click="QuickRegistrationMenuItem_Click" />
            <Separator />
            <MenuItem Header="Cancel" Click="CancelMenuItem_Click" />
        </ContextMenu>
    </Window.ContextMenu>

    <Grid x:Name="OverlayRoot" Background="#01000000">
        <Rectangle Fill="#22030A12" IsHitTestVisible="False" />
        <Canvas x:Name="OverlayCanvas" IsHitTestVisible="False">
            <Line x:Name="VerticalGuide" Stroke="#8AFFFFFF" StrokeThickness="1" StrokeDashArray="2 4" />
            <Line x:Name="HorizontalGuide" Stroke="#8AFFFFFF" StrokeThickness="1" StrokeDashArray="2 4" />

            <Rectangle x:Name="SelectionRectangle"
                       Visibility="Collapsed"
                       Fill="#335DA8FF"
                       Stroke="#FF4DA3FF"
                       StrokeThickness="2" />

            <Ellipse x:Name="PointMarker"
                     Width="18"
                     Height="18"
                     Visibility="Collapsed"
                     Fill="#225DA8FF"
                     Stroke="#FF4DA3FF"
                     StrokeThickness="2" />

            <Border x:Name="Hud"
                    Visibility="Collapsed"
                    MinWidth="126"
                    Background="#E80B1220"
                    BorderBrush="#664DA3FF"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="10,8">
                <StackPanel>
                    <TextBlock x:Name="ModeText" Foreground="#FFF8FAFC" FontWeight="SemiBold" FontSize="12" />
                    <TextBlock x:Name="CoordinateText" Foreground="#FFCBD5E1" FontSize="12" Margin="0,4,0,0" />
                    <TextBlock x:Name="SizeText" Foreground="#FF93C5FD" FontSize="12" Margin="0,2,0,0" />
                </StackPanel>
            </Border>
        </Canvas>
    </Grid>
</Window>